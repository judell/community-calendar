cities/*/*.ics
cities/*/combined.ics
cities/*/events.json

# Auto-generated report (regenerate with scripts/snippet_report.py)
docs/snippet-report.md
cli/cc-cli

# Instance-specific credentials (each fork has its own)
xmlui/config.local.js
