<Component name="SignInDialog" method.open="() => dialog.open()">
  <ModalDialog id="dialog" title="Sign In">
    <VStack gap="$space-3">
      <Button label="Sign in with GitHub" onClick="window.signIn('github')" />
      <Button label="Sign in with Google" onClick="window.signIn('google')" />
    </VStack>
  </ModalDialog>
</Component>
