X-SOURCE-URLS:{"Lancastersciencefactory": "https://lancastersciencefactory.org/event/free-with-admission-chemistry-magic-with-eurofins-lancaster-labs/2026-09-26/"}
X-SOURCE-ID:lancastersciencefactory
X-SOURCE:Lancastersciencefactory
DTSTART;TZID=America/New_York:20260926T110000
DTEND;TZID=America/New_York:20260926T140000
