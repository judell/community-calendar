X-SOURCE-URLS:{"Morehead Planetarium & Science Center": "https://moreheadplanetarium.org/calendar/saturday-science-sparks-science-of-attention/", "UNC Chapel Hill": "https://calendar.unc.edu/event/saturday-science-sparks-the-science-of-attention-juggling-101"}
X-SOURCE-URLS:{"Morehead Planetarium & Science Center": "https://moreheadplanetarium.org/calendar/saturday-science-sparks-science-of-attention/"}
X-SOURCE-ID:morehead_planetarium
