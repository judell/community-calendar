X-SOURCE-URLS:{"NC Museum of Natural Sciences": "https://naturalsciences.org/calendar/event/lunchtime-discovery-look-closer-discovering-the-hidden-world-of-marine-invertebrates/"}
X-SOURCE-ID:nc_natural_sciences
X-SOURCE:NC Museum of Natural Sciences
DTSTART;TZID=America/New_York:20260318T120000
DTEND;TZID=America/New_York:20260318T130000
