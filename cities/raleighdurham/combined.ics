X-SOURCE-URLS:{"Duke Arts": "https://calendar.duke.edu/show?fq=id:CAL-8a00ec9e-9a83ce7f-019a-bbf516cd-00002505demobedework@mysite.edu"}
X-SOURCE-URLS:{"Duke Arts": "https://calendar.duke.edu/show?fq=id:CAL-8a00ec9e-9a83ce7f-019a-bbf516cd-00002505demobedework@mysite.edu"}
X-SOURCE-ID:duke_arts
SUMMARY:Doric String Quartet: Chamber Music Masterclass
DTSTART;VALUE=DATE-TIME:20260328T100000
DTEND;VALUE=DATE-TIME:20260328T120000
UID:4216f857de7459e2b87a414bb35ec983@arts.duke.edu
DESCRIPTION:Presenter: Music\n\nObserve world-class chamber artistry in ac
