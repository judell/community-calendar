END:VEVENT
BEGIN:VEVENT
X-SOURCE-URLS:{"Downtown Durham Inc": "https://downtowndurham.com/event/luewwd-xx-an-arm-wrestling-fundraiser/"}
X-SOURCE-ID:downtown_durham
X-SOURCE:Downtown Durham Inc
