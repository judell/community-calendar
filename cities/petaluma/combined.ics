X-SOURCE-URLS:{"Petaluma River Park Foundation": "https://petalumariverpark.org/calendar/river-park-walk-ars2x-djslw-7jznw-6bahf-fykf4-s9r98-f2zh3-mf3jc-326pj"}
X-SOURCE-ID:petaluma_river_park
SUMMARY:RIVER PARK WALK
DTSTART;TZID=America/Los_Angeles:20260512T090000
DTEND;TZID=America/Los_Angeles:20260512T100000
UID:bf622eca159d0ce505014fb609fee7ef@petalumariverpark.org
DESCRIPTION:Join a weekly walk every Tuesday morning to enjoy the 1.4-mile
  round-trip loop at the Petaluma River Park. You’ll be accompanied by ot
