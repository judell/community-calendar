SUMMARY:Free Farmer's Market - Petaluma Campus
DTSTART;TZID=America/Los_Angeles:20260407T113000
DTEND;TZID=America/Los_Angeles:20260407T133000
DTSTAMP:20250912T111553Z
UID:20260407T183000Z-10029@calendar.santarosa.edu
