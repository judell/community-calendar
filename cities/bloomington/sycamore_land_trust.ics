BEGIN:VEVENT
SUMMARY:Arbor Day Tree Giveaway
DTSTART;VALUE=DATE-TIME:20260426T100000
DTEND;VALUE=DATE-TIME:20260426T140000
UID:866aa65b6999664d4d2ec22fbf6a2a6d@sycamorelandtrust.org
DESCRIPTION:
