BEGIN:VEVENT
X-SOURCE-URLS:{"Sycamore Land Trust": "https://sycamorelandtrust.org/2026/02/preserve-a-preserve-weed-wrangle-at-porter-west-2/"}
X-SOURCE-ID:sycamore_land_trust
SUMMARY:Preserve-a-Preserve: Weed Wrangle at Porter West
DTSTART;VALUE=DATE-TIME:20260320T100000
DTEND;VALUE=DATE-TIME:20260320T120000
UID:7a0f2fe9558579bf51532a13e94f9957@sycamorelandtrust.org
DESCRIPTION:Join us at Porter West Preserve for a Preserve-a-Preserve Weed
  Wrangle where we will focus on cut-stumping invasive woody plants like Bu
 sh Honeysuckle\, Burning Bush and Autumn Olive. Volunteers will learn how 
 these invaders threaten ecosystem biodiversity and gain practical skills i
 n managing them safely and effectively. It’s a rewarding way to get outs
 ide\, make a real impact\, and help keep Porter West thriving for years to
  come!
LOCATION:Porter West Preserve
URL:https://sycamorelandtrust.org/2026/02/preserve-a-preserve-weed-wrangle
 -at-porter-west-2/
X-SOURCE:Sycamore Land Trust
END:VEVENT
