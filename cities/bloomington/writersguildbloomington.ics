 N'>\\n<HTML>\\n<HEAD>\\n<TITLE></TITLE>\\n</HEAD>\\n<BODY><div>\n<h2 class
 ='yiv3584058547MsoNormal' style='text-align: center\;'><span style='font-f
 amily: arial\, sans-serif\;'>LAST SUNDAY POETRY READING & OPEN MIC</span><
 /h2>\n<p class='yiv3584058547MsoNormal' style='text-align: center\;'><span
