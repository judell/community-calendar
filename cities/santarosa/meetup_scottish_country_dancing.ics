BEGIN:VEVENT
X-SOURCE:Meetup: Scottish Country Dancing
X-SOURCE-URL:https://www.meetup.com/scottish-country-dancing/
UID:event_313828913@meetup.com
SEQUENCE:1
DTSTAMP:20260405T030751Z
DTSTART;TZID=America/Los_Angeles:20260406T190000
DTEND;TZID=America/Los_Angeles:20260406T213000
SUMMARY:Class at Monroe Hall
DESCRIPTION:Scottish Country Dancing\nScottish Country Dancing is one of t
 he predecessors of American Square Dancing. Everyone welcome! No partner i
 s required. Comfortable shoes and a love of dance is all you need. Enjoy l
 ive music!\n\nClasses are held every Monday with basics from 7:00-8:15\, a
 nd more experienced dancers at 8:30-9:30.\n\nFirst time free\, then $10 fo
 r first or second session\, or $12 for whole evening.
URL;VALUE=URI:https://www.meetup.com/scottish-country-dancing/events/31382
 8913/
STATUS:CONFIRMED
CREATED:20260318T031957Z
LAST-MODIFIED:20260318T031957Z
CLASS:PUBLIC
END:VEVENT
