DTEND;TZID=PDT;VALUE=DATE-TIME:20260313T220000
UID:260312qpmtp0W52UCQ7clzOKJJAw
DESCRIPTION:Friday night stand-up comedy in Downtown Santa Rosa\n\nVIP TAB
