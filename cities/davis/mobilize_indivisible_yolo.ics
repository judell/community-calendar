BEGIN:VEVENT
SUMMARY:Woodland CA Visibility Brigade Thursdays 4:30pm over Highway 113
DTSTART;TZID=America/Los_Angeles:20260409T163000
DTEND;TZID=America/Los_Angeles:20260409T180000
UID:b50e23db4ee495902f3588b9903c305d@mobilize.us
